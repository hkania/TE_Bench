def get_flag(config, key, default=True):
    """
    Read a boolean flag from Snakemake config.
    Returns True/False.
    Default is True if the key is missing.
    Accepts 'true'/'false' (case-insensitive) or actual booleans.
    """
    val = config.get(key, default)
    if isinstance(val, bool):
        return val
    return str(val).strip().lower() == "true"

