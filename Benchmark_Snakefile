import sys

def print_custom_help():
    help_text = f"""
TE_Bench Snakemake Workflow, Stages 3 & 4 Comprehensive and Selective Benchmarking
Generates statistics and plots for TE annotations depending on the provided configuration flags.

Usage:
    snakemake -s Benchmark_Snakefile [options] --cores N

Optional configuration flags (from config_benchmark.yaml):

stg3          : Run stage 3 analysis (default: True)
stg4          : Run stage 4 TE type analysis (default: True)
clean_eg      : Run earlGrey-like CSV generation (default: True)
clean_rm      : Run RepeatModeler2-like CSV generation (default: True)
clean_edta    : Run EDTA-like CSV generation (default: True)
radar         : Generate annotation statistics radar plots (default: True)
nest          : Perform nested TE analysis (default: True; will run comprehensive if stg3 is true and selective is stg4 is true or both if both stg3 and stg4 are true)
pie           : Generate comprehensive annotation TE class pie charts (default: True)
iden          : Perform percent identity analysis if Garlic simulation was used (default: True)
test          : Run test workflow using provided data from TE_Bench (default: False)
ref_ext       : Reference CSV suffix (default: _Garlic)
RM2_gff_ext   : RepeatModeler2 GFF suffix (default: _RM2.gff, does not apply if clean_rm flag is made false)
RM2_fasta_ext : RepeatModeler2 FASTA suffix (default: _RM2.fa, does not apply if clean_rm flag is made false)
EG_gff_ext    : earlGrey GFF suffix (default: EG.gff, does not apply if clean_eg flag is made false)
EDTA_gff_ext  : EDTA GFF suffix (default: EDTA.gff, does not apply if clean_edta flag is made false)
seq_len       : Length of reference file(s) sequence (default: 100000000)
inserts_dir   : Directory containing the inserts file (default: input/annotationdata/testing for test. For non-test data generated with earlier workflow stages, please specify the output/sim_fastas/seq_name/seq_name_split directory and replace seq_name with your overal model sequence name to capture all iterations of a simulation. Does not apply if iden flag is made false due to non-Garlic reference file(s))
extras        : Additional category within 'column' (see below) to include in pie charts and identity regressions (default: Unknown elements)
column        : Column to filter CSV files on (default: V5 which holds major TE class)

Examples:
    snakemake -s Benchmark_Snakefile --cores 1 --rerun-incomplete (ALL DEFAULTS)
    snakemake -s Benchmark_Snakefile --cores 1 --rerun-incomplete --config test=true (RUN ON PROVIDED TEST DATA)
    snakemake -s Benchmark_Snakefile --cores 1 --rerun-incomplete --config clean_eg=false nest=false (CHANGE SOME DEFAULTS)
"""
    print(help_text)
    sys.exit(0)

