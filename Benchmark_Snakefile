if STAGE3:
    rule comprehensive_calculate_statistics:
        input:
            tests=comprehensive_stats_input_csvs,
            ref_csv=os.path.join(workflow.basedir, "output/cleaned_csvs/{seq_name}/full/comprehensive/{seq_name}" + ref_csv_ext)
        output:
            stats=os.path.join(workflow.basedir, "output/stats/{seq_name}/comprehensive/{seq_name}_stats.txt")
        params:
            seq_len=config["seq_len"]
        run:
            import subprocess, glob, os, re
            seq_name = wildcards.seq_name
            ref_ext2 = ref_csv_ext
            csvs = glob.glob(f"output/cleaned_csvs/{seq_name}/full/comprehensive/*.csv")
            if not csvs:
                raise ValueError(f"No CSV files found for sequence {seq_name}")
            ref_csvs = [f for f in csvs if ref_ext2 in os.path.basename(f)]
            if not ref_csvs:
                raise ValueError(f"No reference CSV found for {seq_name} with extension {ref_ext2}")
            for ref_csv in ref_csvs:
                base = os.path.basename(ref_csv)
                match = re.search(rf"{re.escape(ref_ext2)}(?:_(.+))?\.csv$", base)
                ref_type = match.group(1) if match else None
                non_ref_csv = [f for f in csvs if f != ref_csv]

            os.makedirs(os.path.dirname(output.stats), exist_ok=True)

            cmd = [
                "python3",
                "./scripts/generate_stats.py",
                ref_csv,
                str(params.seq_len),
                output.stats,
            ] + non_ref_csv
            subprocess.run(cmd, check=True)

