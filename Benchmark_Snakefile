            config_args = sys.argv[i+1].split(",")
            for j, c in enumerate(config_args):
                if c.lower() in ["help", "h"]:
                    config_args[j] = "help=true"
            sys.argv[i+1] = ",".join(config_args)

if any("help=true" in arg.lower() for arg in sys.argv):
