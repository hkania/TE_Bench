# Load the config file
configfile: "config_option3.yaml"
seq_names="droMelTEST"

localrules: garlic_to_csv

rule all:
    input:
        [
            expand(
                "output/cleaned_csvs/{seq_name}/{seq_name}_Garlic_{num}_Garlic.csv",
                seq_name=seq_names,
                num=range(1, config["num_sequences"] + 1)
            ),
            expand(
                "output/garlic_gff_generation/{seq_name}/gffs/{seq_name}_{num}_Garlic.gff",
                seq_name=seq_names,
                num=range(1, config["num_sequences"] + 1)
            )
        ]

rule run_garlic_gff_generation:
    input:
        log=config["GARLIC_LOG_FILE"]
    output:
        gffs=expand(
            "output/garlic_gff_generation/{seq_name}/gffs/{seq_name}_{num}_Garlic.gff",
            seq_name=seq_names,
            num=range(1, config["num_sequences"] + 1)
        )
    params:
        end=config["num_sequences"] - 1,
        seq_name=seq_names,
        awk_script_1=os.path.join(workflow.basedir, "scripts/sequence_start_stop"),
        awk_script_2=os.path.join(workflow.basedir, "scripts/nested_gff"),
        garlic_out_directory=os.path.join(workflow.basedir, "output/garlic_gff_generation", seq_names),
        garlic_in_directory=os.path.join(workflow.basedir, "input/option3")
    conda:
        "envs/blast2.yaml"
    resources:
        mem_mb = 10000,
        runtime=1440
    threads: 4
    shell:
        """
        ./scripts/garlic_gff_gen.sh {params.end} {params.seq_name} {input.log} {params.garlic_out_directory} {params.garlic_in_directory} {params.awk_script_1} {params.awk_script_2}
        """
         
rule garlic_to_csv:
    input:
        gff="output/garlic_gff_generation/{seq_name}/gffs/{seq_name}_{num}_Garlic.gff"
    output:
        csv="output/cleaned_csvs/{seq_name}/{seq_name}_Garlic_{num}_Garlic.csv"
    script:
        "scripts/Garlic_gff_to_csv.R"
