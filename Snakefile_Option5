# Load the config file
configfile: "config_option5.yaml"

target_types = config["target_types"]

import glob
import os

ref_ext = config["ref_csv_ext"]

seq_dirs = [d for d in glob.glob("output/cleaned_csvs/*") if os.path.isdir(d)]
seq_names = [os.path.basename(d) for d in seq_dirs]
csvs = glob.glob("output/cleaned_csvs/*/*.csv")

program_names = sorted(set([os.path.splitext(os.path.basename(f))[0].split("_")[-1] for f in csvs]))

# Rule to ensure all CSV outputs and the statistics file are generated

rule all:
    input:
        [
            expand(
                os.path.join(workflow.basedir, "output/cleaned_csvs/{seq_name}/te_types/{seq_name}_{prog}_{type}.csv"),
                type=target_types,
                seq_name=seq_names,
                prog=program_names
            ),
            expand(
                os.path.join(workflow.basedir, "output/stats/{seq_name}/te_types/{seq_name}_{type}_stats.txt"),
                type=target_types,
                seq_name=seq_names,
                prog=program_names
            ),
            expand(
                os.path.join(workflow.basedir, "output/stats/{seq_name}/te_types/plots/{seq_name}_{type}_plot_stats.pdf"),
                type=target_types,
                seq_name=seq_names,
                prog=program_names
            ),
        ]

# Filter CSVs for specific TE types as designated in the config file
rule type_csvs:
    input:
        csv=os.path.join(workflow.basedir, "output/cleaned_csvs/{seq_name}/{seq_name}_{prog}.csv")
    output:
        csv=os.path.join(workflow.basedir, "output/cleaned_csvs/{seq_name}/te_types/{seq_name}_{prog}_{type}.csv")
    params:
        column=config["column"]
    script:
        "scripts/filter_csv.R"    

# Define input csvs for the TE type statistics calculation
def stats_input_csvs(wildcards):
    return expand(
        os.path.join(
            workflow.basedir,
            "output/cleaned_csvs/{seq_name}/te_types/{seq_name}_{prog}_{type}.csv"
        ),
	    seq_name=wildcards.seq_name,
        prog=program_names,
        type=target_types
    )

# Run MCC scores on specific TE types as designated in the config file
rule type mcc_scores:
    input:
        tests=stats_input_csvs
    output:
        stats=os.path.join(workflow.basedir, "output/stats/{seq_name}/te_types/{seq_name}_{type}_stats.txt")
    params:
        seq_len=config["seq_len"]
    run:
        import subprocess, glob, os, re
        seq_name = wildcards.seq_name
        csv_type = wildcards.type
        ref_ext = config["ref_csv_ext"]
        csvs = glob.glob(f"output/cleaned_csvs/{seq_name}/te_types/*_{csv_type}.csv")
        if not csvs:
            raise ValueError(f"No CSV files found for sequence {seq_name}")
        ref_csvs = [f for f in csvs if ref_ext in os.path.basename(f)]
        if not ref_csvs:
            raise ValueError(f"No reference CSV found for {seq_name} with extension {ref_ext}")
        for ref_csv in ref_csvs:
            base = os.path.basename(ref_csv)
            match = re.search(rf"{re.escape(ref_ext)}(?:_(.+))?\.csv$", base)
            ref_type = match.group(1) if match else None

            if ref_type:
                non_ref_csv = [f for f in csvs if f != ref_csv and f.endswith(f"{ref_type}.csv")]
            else:
                non_ref_csv = [f for f in csvs if f != ref_csv]

        cmd = [
            "python3", 
            "./scripts/generate_stats.py",
            wildcards.type,
            ref_csv,
            str(params.seq_len),
            output.stats,
        ] + non_ref_csv
        subprocess.run(cmd, check=True)

# Run hexagon plot on specific TE types as designated in the config file
rule type_hexagon_plot:
    input:
        stats=os.path.join(workflow.basedir, "output/stats/{seq_name}/te_types/{seq_name}_{type}_stats.txt")
    output:
        plot=os.path.join(workflow.basedir, "output/stats/{seq_name}/te_types/plots/{seq_name}_{type}_plot_stats.pdf")
    shell:
        """
        python3 ./scripts/view_stats.py {input.stats} {output.plot} {wildcards.seq_name} {wildcards.type}
        """
