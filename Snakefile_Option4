# Build nested pie chart depicting total number of elements in reference file by TE type and percent of elements covered by each test pipeline
rule coverage_pie_chart:
    input:
        test=os.path.join(workflow.basedir, "output/cleaned_csvs/{seq_name}/{seq_name}_{prog}.csv")
    output:
        cov_csv=os.path.join(workflow.basedir, "output/cleaned_csvs/{seq_name}/coverage_csvs/{seq_name}_{prog}_cov.csv"),
        pdf=os.path.join(workflow.basedir, "output/stats/{seq_name}/plots/{seq_name}_{prog}_coverage_piechart.pdf")
    params:
        seq_len=config["seq_len"],
        extras=config["extras"]
    run:
        import subprocess, glob, os, re

        seq_name = wildcards.seq_name
        prog = wildcards.prog
        ref_ext = config["ref_csv_ext"]

        csvs = glob.glob(f"output/cleaned_csvs/{seq_name}/*.csv")

        # Reference CSV
        ref_csvs = [f for f in csvs if ref_ext in os.path.basename(f)]
        if len(ref_csvs) != 1:
            raise ValueError(f"Expected exactly 1 reference CSV, found: {ref_csvs}")
        ref_csv = ref_csvs[0]

        # Test CSV matching the current prog
        test_csvs = [f for f in csvs if prog in os.path.basename(f)]
        if len(test_csvs) != 1:
            raise ValueError(f"Expected exactly 1 test CSV for prog {prog}, found: {test_csvs}")
        test_csv = test_csvs[0]

        cmd = [
            "python3",
            "./scripts/plot_covered.py",
            seq_name,
            output.pdf,
            output.cov_csv,
            str(params.seq_len),
            ref_csv,
            test_csv,
            "params.extras"
        ]
        subprocess.run(cmd, check=True)

