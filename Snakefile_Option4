# Define input csvs for the statistics calculation
def stats_input_csvs(wildcards):
    return expand(
        os.path.join(
            workflow.basedir,
            "output/cleaned_csvs/{seq_name}/{seq_name}_{prog}.csv"
        ),
	seq_name=wildcards.seq_name,
        prog=program_names
    )

# Generate statistics across the whole genome and all inserted elements
rule calculate_statistics:
    input:
        tests=stats_input_csvs
    output:
        stats=os.path.join(workflow.basedir, "output/stats/{seq_name}/{seq_name}_stats.txt")
    params:
        seq_len=config["seq_len"]
    run:
        import subprocess, glob, os, re
        seq_name = wildcards.seq_name
        ref_ext = config["ref_csv_ext"]
        csvs = glob.glob(f"output/cleaned_csvs/{seq_name}/*.csv")
        if not csvs:
            raise ValueError(f"No CSV files found for sequence {seq_name}")
        ref_csvs = [f for f in csvs if ref_ext in os.path.basename(f)]
        if not ref_csvs:
            raise ValueError(f"No reference CSV found for {seq_name} with extension {ref_ext}")
        for ref_csv in ref_csvs:
            base = os.path.basename(ref_csv)
            match = re.search(rf"{re.escape(ref_ext)}(?:_(.+))?\.csv$", base)
            ref_type = match.group(1) if match else None
            non_ref_csv = [f for f in csvs if f != ref_csv]

        os.makedirs(os.path.dirname(output.stats), exist_ok=True)

        cmd = [
            "python3",
            "./scripts/generate_stats.py",
            ref_csv,
            str(params.seq_len),
            output.stats,
        ] + non_ref_csv
        subprocess.run(cmd, check=True)

