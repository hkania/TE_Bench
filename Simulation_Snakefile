def print_custom_help():
    help_text = f"""
TE_Bench Snakemake Workflow, Stage 1 Simulation of TE FASTA Sequences with Garlic
Simulates sequences with and without TE inserts based on model genomic data

Usage:
    snakemake --profile profile/ --conda-frontend conda --conda-prefix ~/.snakemake/conda -s Simulation_Snakefile [options]

Optional configuration flags (from config_simulation.yaml, or override in command line):

test         : Run test workflow using provided data from TE_Bench (default: False)
dfam         : Run the simulation using user-specified Dfam data (default: True)
repbase      : Run the simulation using user-specified RepBase data (default: False)
size         : Specifies the length in base pairs to simulate per artificial sequence (default: 1000 for quick testing purposes)
num_seqs     : Specifies the number of artificial sequences to simulate per provided model (default: 2)

Examples:
    snakemake -s Simulation_Snakefile --cores 1 --rerun-incomplete (ALL DEFAULTS)
    snakemake -s Simulation_Snakefile --cores 1 --rerun-incomplete --config test=true repbase=true (RUN ON PROVIDED REPBASE TEST DATA)
"""
    print(help_text)
    sys.exit(0)

for i, arg in enumerate(sys.argv):
    if arg.startswith("--config"):
        if i+1 < len(sys.argv):
            config_args = sys.argv[i+1].split(",")
            for j, c in enumerate(config_args):
                if c.lower() in ["help", "h"]:
                    config_args[j] = "help=true"
            sys.argv[i+1] = ",".join(config_args)

if any("help=true" in arg.lower() for arg in sys.argv):
    print_custom_help()

def get_flag(config, key, default=True):
    """
    Read a boolean flag from Snakemake config.
    Returns True/False.
    Default is True if the key is missing.
    Accepts 'true'/'false' (case-insensitive) or actual booleans.
    """
    val = config.get(key, default)
    if isinstance(val, bool):
        return val
    return str(val).strip().lower() == "true"

