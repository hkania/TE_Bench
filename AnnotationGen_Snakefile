rule garlic_to_csv:
    input:
        gff=os.path.join(workflow.basedir, "output/garlic_gff_generation/{seq_name}/gffs/{seq_name}_{num}_Garlic.gff")
    output:
        csv=os.path.join(workflow.basedir, "output/cleaned_csvs/{seq_name}_{num}/full/comprehensive/{seq_name}_{num}_Garlic.csv")
    script:
        "scripts/Garlic_gff_to_csv.R"
